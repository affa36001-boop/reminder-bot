# Токен Telegram-бота от @BotFather
BOT_TOKEN=123456:ABC-DEF_your_token_here

# Путь к SQLite базе (или DSN PostgreSQL, например: postgresql+asyncpg://user:pass@host/db)
DATABASE_URL=sqlite+aiosqlite:///./reminders.db

# Часовой пояс по умолчанию для новых пользователей
DEFAULT_TIMEZONE=Europe/Moscow

# Уровень логирования (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
